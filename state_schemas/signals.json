{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Signals Schema",
  "type": "object",
  "required": [
    "schema_version",
    "date",
    "generated_at",
    "active_signals",
    "backtest_performance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "date": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "active_signals": {
      "type": "array"
    },
    "backtest_performance": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
