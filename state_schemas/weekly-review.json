{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Weekly Review Schema",
  "type": "object",
  "required": [
    "schema_version",
    "week_ending",
    "week_number",
    "cold_start_day",
    "sats_vs_hodl",
    "weekly_verdict",
    "bybit_account_type"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "week_ending": {
      "type": "string"
    },
    "week_number": {
      "type": "integer"
    },
    "cold_start_day": {
      "type": "integer"
    },
    "sats_vs_hodl": {
      "type": "integer"
    },
    "weekly_verdict": {
      "type": "string"
    },
    "bybit_account_type": {
      "type": "string",
      "enum": ["demo", "live"]
    }
  },
  "additionalProperties": true
}
