{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chief Triage Schema",
  "type": "object",
  "required": [
    "schema_version",
    "produced_at",
    "severity",
    "issues"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "produced_at": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": ["OK", "WARNING", "CRITICAL"]
    },
    "issues": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
