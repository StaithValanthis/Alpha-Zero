{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "System Log Schema",
  "type": "object",
  "required": [
    "schema_version",
    "last_updated",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "last_updated": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "timestamp",
          "event",
          "message"
        ],
        "properties": {
          "timestamp": {
            "type": "string"
          },
          "event": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": true
}
