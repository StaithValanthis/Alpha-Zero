{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Research Schema",
  "type": "object",
  "required": [
    "schema_version",
    "date",
    "produced_at",
    "adjudication_status",
    "approved_hypotheses",
    "rejected_hypotheses"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "date": {
      "type": "string"
    },
    "produced_at": {
      "type": "string"
    },
    "adjudication_status": {
      "type": "string"
    },
    "approved_hypotheses": {
      "type": "array"
    },
    "rejected_hypotheses": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
