{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Anomaly State Schema",
  "type": "object",
  "required": [
    "schema_version",
    "current_anomalies",
    "auto_pause_signal_watcher",
    "last_updated"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "current_anomalies": {
      "type": "array"
    },
    "auto_pause_signal_watcher": {
      "type": "boolean"
    },
    "last_updated": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
