{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Symbol Watchlist Schema",
  "type": "object",
  "required": [
    "schema_version",
    "symbols",
    "last_updated"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "symbols": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_updated": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
