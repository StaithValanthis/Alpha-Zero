{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pipeline State Schema",
  "type": "object",
  "required": [
    "schema_version",
    "date",
    "scheduled_today",
    "completed_today",
    "failed_today"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "date": {
      "type": "string"
    },
    "scheduled_today": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "completed_today": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failed_today": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
